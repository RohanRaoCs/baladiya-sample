<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ai_draft_wizard_form" model="ir.ui.view">
        <field name="name">baladiya.ai.draft.wizard.form</field>
        <field name="model">baladiya.ai.draft.wizard</field>
        <field name="arch" type="xml">
            <form string="AI Response Drafter">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="transition_type"/>
                </group>
                <group>
                    <button name="action_generate_draft" string="Generate AI Draft"
                            type="object" class="btn-primary mb-3" icon="fa-magic"/>
                </group>
                <group>
                    <field name="ai_draft_subject" placeholder="Email subject..."/>
                </group>
                <field name="ai_draft_body" placeholder="AI will generate a message draft here. You can edit it before sending."/>
                <footer>
                    <button name="action_send_message" string="Send to Citizen"
                            type="object" class="btn-primary" icon="fa-paper-plane"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
