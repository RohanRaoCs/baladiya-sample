<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_reject_wizard_form" model="ir.ui.view">
        <field name="name">baladiya.reject.wizard.form</field>
        <field name="model">baladiya.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Request">
                <group>
                    <field name="request_id" readonly="1"/>
                    <field name="reason" placeholder="Please explain the reason for rejection..."
                           required="1"/>
                </group>
                <footer>
                    <button name="action_confirm_reject" string="Confirm Rejection"
                            type="object" class="btn-danger"/>
                    <button special="cancel" string="Cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
