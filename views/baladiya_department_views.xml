<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_department_list" model="ir.ui.view">
        <field name="name">baladiya.department.list</field>
        <field name="model">baladiya.department</field>
        <field name="arch" type="xml">
            <list>
                <field name="code"/>
                <field name="name"/>
                <field name="manager_id" widget="many2one_avatar_user"/>
                <field name="request_count"/>
                <field name="pending_count"/>
                <field name="avg_processing_days"/>
            </list>
        </field>
    </record>

    <record id="view_department_form" model="ir.ui.view">
        <field name="name">baladiya.department.form</field>
        <field name="model">baladiya.department</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-tasks" type="object"
                                name="action_view_requests">
                            <field name="request_count" widget="statinfo" string="Requests"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-clock-o" type="object"
                                name="action_view_pending">
                            <field name="pending_count" widget="statinfo" string="Pending"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Department Name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="manager_id"/>
                            <field name="active" invisible="1"/>
                        </group>
                        <group>
                            <field name="avg_processing_days"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <group string="Team Members">
                        <field name="member_ids" widget="many2many_tags" nolabel="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">baladiya.department</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
