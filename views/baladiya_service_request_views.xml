<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== KANBAN VIEW ==================== -->
    <record id="view_service_request_kanban" model="ir.ui.view">
        <field name="name">baladiya.service.request.kanban</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column" sample="1">
                <field name="state"/>
                <field name="sla_status"/>
                <field name="priority"/>
                <field name="tracking_code"/>
                <field name="citizen_id"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="officer_id"/>
                <field name="deadline"/>
                <field name="fee_paid"/>
                <progressbar field="sla_status"
                    colors='{"on_track": "success", "at_risk": "warning", "overdue": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <div class="d-flex justify-content-between mb-1">
                            <strong>
                                <field name="tracking_code"/>
                            </strong>
                            <field name="priority" widget="priority"/>
                        </div>
                        <field name="citizen_id" widget="many2one_avatar"/>
                        <div class="mt-1">
                            <field name="category_id" class="fw-bold"/>
                        </div>
                        <div class="text-muted small">
                            <field name="department_id"/>
                        </div>
                        <footer class="pt-2">
                            <div class="d-flex align-items-center justify-content-between w-100">
                                <span t-if="record.sla_status.raw_value == 'overdue'"
                                      class="badge text-bg-danger">Overdue</span>
                                <span t-elif="record.sla_status.raw_value == 'at_risk'"
                                      class="badge text-bg-warning">At Risk</span>
                                <span t-elif="record.sla_status.raw_value == 'on_track'"
                                      class="badge text-bg-success">On Track</span>
                                <span t-else=""/>
                                <field name="officer_id" widget="many2one_avatar_user"/>
                            </div>
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ==================== LIST VIEW ==================== -->
    <record id="view_service_request_list" model="ir.ui.view">
        <field name="name">baladiya.service.request.list</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <list decoration-danger="sla_status == 'overdue'"
                  decoration-warning="sla_status == 'at_risk'"
                  sample="1" multi_edit="1">
                <field name="name"/>
                <field name="tracking_code"/>
                <field name="citizen_id" widget="many2one_avatar"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="district"/>
                <field name="state" widget="badge"
                       decoration-success="state in ('approved','done')"
                       decoration-info="state in ('submitted','under_review','in_progress')"
                       decoration-warning="state in ('inspection','pending_approval')"
                       decoration-danger="state in ('rejected','cancelled')"/>
                <field name="priority" widget="priority"/>
                <field name="officer_id" widget="many2one_avatar_user"/>
                <field name="submission_date"/>
                <field name="deadline"/>
                <field name="sla_status" widget="badge"
                       decoration-success="sla_status == 'on_track'"
                       decoration-warning="sla_status == 'at_risk'"
                       decoration-danger="sla_status == 'overdue'"/>
                <field name="fee_amount" string="Fee (AED)"/>
                <field name="fee_paid"/>
            </list>
        </field>
    </record>

    <!-- ==================== FORM VIEW ==================== -->
    <record id="view_service_request_form" model="ir.ui.view">
        <field name="name">baladiya.service.request.form</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_submit" string="Submit"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_review" string="Start Review"
                            type="object" class="btn-primary"
                            invisible="state != 'submitted'"/>
                    <button name="action_start_progress" string="Start Processing"
                            type="object" class="btn-primary"
                            invisible="state != 'under_review'"/>
                    <button name="action_start_inspection" string="Send to Inspection"
                            type="object"
                            invisible="state != 'in_progress'"/>
                    <button name="action_request_approval" string="Request Approval"
                            type="object" class="btn-primary"
                            invisible="state not in ('in_progress', 'inspection')"/>
                    <button name="action_approve" string="Approve"
                            type="object" class="btn-success"
                            invisible="state != 'pending_approval'"
                            groups="baladiya.group_baladiya_manager"/>
                    <button name="action_complete" string="Mark Complete"
                            type="object" class="btn-success"
                            invisible="state != 'approved'"/>
                    <button name="action_reject" string="Reject"
                            type="object" class="btn-danger"
                            invisible="state in ('draft','done','rejected','cancelled')"
                            groups="baladiya.group_baladiya_manager"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('done','cancelled')"/>
                    <button name="action_reset_to_draft" string="Reset to Draft"
                            type="object"
                            invisible="state not in ('rejected','cancelled')"/>
                    <button name="action_ai_draft_response" string="AI Draft Response"
                            type="object" class="btn-warning"
                            icon="fa-magic"
                            invisible="state in ('draft','done','cancelled')"
                            groups="baladiya.group_baladiya_officer"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,submitted,under_review,in_progress,pending_approval,approved,done"/>
                </header>
                <sheet>
                    <!-- Overdue ribbon -->
                    <widget name="web_ribbon" title="Overdue" bg_color="text-bg-danger"
                            invisible="sla_status != 'overdue'"/>
                    <!-- Stat buttons -->
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" icon="fa-paperclip"
                                name="action_view_attachments" type="object"
                                invisible="document_count == 0">
                            <field name="document_count" widget="statinfo" string="Documents"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                        <h3 class="text-muted">
                            Tracking: <field name="tracking_code" readonly="1"/>
                        </h3>
                    </div>
                    <!-- AI TRIAGE PANEL (Brain 1) -->
                    <div class="alert alert-info" role="alert"
                         invisible="not ai_triage_done"
                         groups="baladiya.group_baladiya_officer">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <h5 class="mb-0"><i class="fa fa-robot"/> AI Triage Recommendation</h5>
                            <span class="badge text-bg-primary">
                                Confidence: <field name="ai_triage_confidence" nolabel="1"/>%
                            </span>
                        </div>
                        <div class="row mb-2">
                            <div class="col-md-4">
                                <strong>Suggested Priority:</strong>
                                <field name="ai_suggested_priority" nolabel="1"/>
                            </div>
                            <div class="col-md-4">
                                <strong>Suggested Dept:</strong>
                                <field name="ai_suggested_department_id" nolabel="1"/>
                            </div>
                            <div class="col-md-4">
                                <strong>Suggested Officer:</strong>
                                <field name="ai_suggested_officer_id" nolabel="1"/>
                            </div>
                        </div>
                        <div class="mb-2">
                            <strong>AI Reasoning:</strong>
                            <field name="ai_triage_reasoning" nolabel="1"/>
                        </div>
                        <div class="d-flex gap-2">
                            <button name="action_accept_ai_triage" string="Accept AI Suggestions"
                                    type="object" class="btn btn-sm btn-success"
                                    icon="fa-check"/>
                            <button name="action_dismiss_ai_triage" string="Dismiss"
                                    type="object" class="btn btn-sm btn-secondary"
                                    icon="fa-times"/>
                        </div>
                    </div>

                    <group>
                        <group string="Request Information">
                            <field name="citizen_id"/>
                            <field name="category_id"/>
                            <field name="department_id"/>
                            <field name="priority" widget="priority"/>
                            <field name="district"/>
                            <field name="address"/>
                        </group>
                        <group string="Assignment &amp; Dates">
                            <field name="officer_id"/>
                            <field name="approver_id" invisible="state not in ('approved','done')"/>
                            <field name="submission_date"/>
                            <field name="deadline"/>
                            <field name="completion_date" invisible="state != 'done'"/>
                            <field name="sla_status" widget="badge"
                                   decoration-success="sla_status == 'on_track'"
                                   decoration-warning="sla_status == 'at_risk'"
                                   decoration-danger="sla_status == 'overdue'"/>
                        </group>
                    </group>
                    <group>
                        <group string="Financial">
                            <field name="fee_amount"/>
                            <field name="fee_paid"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Request Details" name="details">
                            <field name="description" placeholder="Describe the service request..."/>
                        </page>
                        <page string="Documents" name="documents">
                            <field name="attachment_ids" widget="many2many_binary"/>
                            <!-- AI Document Validation (Brain 2) -->
                            <div groups="baladiya.group_baladiya_officer" class="mt-3">
                                <button name="action_ai_validate_documents" string="Validate Documents with AI"
                                        type="object" class="btn btn-sm btn-warning mb-2"
                                        icon="fa-magic"
                                        invisible="state == 'draft'"/>
                                <div invisible="not ai_doc_validation_done"
                                     class="alert alert-secondary">
                                    <h6><i class="fa fa-check-circle"/> AI Document Assessment</h6>
                                    <div class="row">
                                        <div class="col-md-3">
                                            <strong>Completeness:</strong>
                                            <field name="ai_doc_completeness" nolabel="1" widget="progressbar"/>
                                        </div>
                                    </div>
                                    <div class="row mt-2">
                                        <div class="col-md-6">
                                            <strong>Identified:</strong>
                                            <field name="ai_doc_identified" nolabel="1"/>
                                        </div>
                                        <div class="col-md-6">
                                            <strong>Missing:</strong>
                                            <field name="ai_doc_missing" nolabel="1"
                                                   class="text-danger"/>
                                        </div>
                                    </div>
                                    <div class="mt-2">
                                        <strong>Assessment:</strong>
                                        <field name="ai_doc_assessment" nolabel="1"/>
                                    </div>
                                </div>
                            </div>
                        </page>
                        <page string="Internal Notes" name="internal"
                              groups="baladiya.group_baladiya_officer">
                            <field name="internal_notes" placeholder="Internal notes for staff only..."/>
                        </page>
                        <page string="Citizen Feedback" name="feedback"
                              invisible="state != 'done'">
                            <group>
                                <field name="citizen_rating" widget="priority"/>
                                <field name="citizen_feedback"/>
                            </group>
                        </page>
                        <page string="AI Insights" name="ai_insights"
                              groups="baladiya.group_baladiya_officer">
                            <div class="mb-3">
                                <button name="action_ai_generate_insights"
                                        string="Generate AI Insights"
                                        type="object" class="btn btn-warning"
                                        icon="fa-magic"
                                        invisible="state == 'draft'"/>
                                <span class="text-muted ms-2" invisible="not ai_insights_date">
                                    Last generated: <field name="ai_insights_date" nolabel="1" widget="datetime"/>
                                </span>
                            </div>
                            <div invisible="not ai_summary">
                                <group>
                                    <group>
                                        <field name="ai_summary"/>
                                        <field name="ai_sentiment" widget="badge"
                                               decoration-danger="ai_sentiment == 'frustrated'"
                                               decoration-warning="ai_sentiment == 'urgent'"
                                               decoration-success="ai_sentiment == 'neutral'"/>
                                    </group>
                                </group>
                                <group string="Detected Patterns">
                                    <field name="ai_patterns" nolabel="1"/>
                                </group>
                                <group string="Recommended Action">
                                    <field name="ai_recommended_action" nolabel="1"/>
                                </group>
                            </div>
                        </page>
                        <page string="Rejection" name="rejection"
                              invisible="state != 'rejected'">
                            <group>
                                <field name="rejection_reason"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ==================== SEARCH VIEW ==================== -->
    <record id="view_service_request_search" model="ir.ui.view">
        <field name="name">baladiya.service.request.search</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="tracking_code"/>
                <field name="citizen_id"/>
                <field name="category_id"/>
                <field name="department_id"/>
                <field name="officer_id"/>
                <separator/>
                <filter string="My Assigned" name="my_assigned"
                        domain="[('officer_id', '=', uid)]"/>
                <filter string="Overdue" name="overdue"
                        domain="[('sla_status', '=', 'overdue')]"/>
                <filter string="At Risk" name="at_risk"
                        domain="[('sla_status', '=', 'at_risk')]"/>
                <separator/>
                <filter string="Draft" name="draft" domain="[('state', '=', 'draft')]"/>
                <filter string="Submitted" name="submitted" domain="[('state', '=', 'submitted')]"/>
                <filter string="Under Review" name="under_review" domain="[('state', '=', 'under_review')]"/>
                <filter string="In Progress" name="in_progress" domain="[('state', '=', 'in_progress')]"/>
                <filter string="Pending Approval" name="pending_approval" domain="[('state', '=', 'pending_approval')]"/>
                <filter string="Completed" name="done" domain="[('state', '=', 'done')]"/>
                <filter string="Rejected" name="rejected" domain="[('state', '=', 'rejected')]"/>
                <separator/>
                <group>
                    <filter string="Department" name="group_department" context="{'group_by': 'department_id'}"/>
                    <filter string="Service Type" name="group_category" context="{'group_by': 'category_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="District" name="group_district" context="{'group_by': 'district'}"/>
                    <filter string="Priority" name="group_priority" context="{'group_by': 'priority'}"/>
                    <filter string="Officer" name="group_officer" context="{'group_by': 'officer_id'}"/>
                    <filter string="Submission Month" name="group_month" context="{'group_by': 'submission_date:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ==================== GRAPH VIEWS ==================== -->
    <record id="view_service_request_graph_bar" model="ir.ui.view">
        <field name="name">baladiya.service.request.graph.bar</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <graph string="Requests by Department" type="bar" sample="1">
                <field name="department_id"/>
                <field name="id" type="measure" string="Count"/>
            </graph>
        </field>
    </record>

    <record id="view_service_request_graph_pie" model="ir.ui.view">
        <field name="name">baladiya.service.request.graph.pie</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <graph string="Requests by Status" type="pie" sample="1">
                <field name="state"/>
                <field name="id" type="measure" string="Count"/>
            </graph>
        </field>
    </record>

    <record id="view_service_request_graph_line" model="ir.ui.view">
        <field name="name">baladiya.service.request.graph.line</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <graph string="Requests Trend" type="line" sample="1">
                <field name="submission_date" interval="month"/>
                <field name="id" type="measure" string="Count"/>
            </graph>
        </field>
    </record>

    <record id="view_service_request_pivot" model="ir.ui.view">
        <field name="name">baladiya.service.request.pivot</field>
        <field name="model">baladiya.service.request</field>
        <field name="arch" type="xml">
            <pivot string="Service Request Analysis" sample="1">
                <field name="department_id" type="row"/>
                <field name="state" type="col"/>
                <field name="id" type="measure" string="Count"/>
            </pivot>
        </field>
    </record>

    <!-- ==================== ACTIONS ==================== -->
    <record id="action_service_request" model="ir.actions.act_window">
        <field name="name">Service Requests</field>
        <field name="res_model">baladiya.service.request</field>
        <field name="view_mode">kanban,list,form,graph,pivot</field>
        <field name="search_view_id" ref="view_service_request_search"/>
        <field name="context">{'search_default_my_assigned': 0}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No service requests yet
            </p>
            <p>Service requests from citizens will appear here.</p>
        </field>
    </record>

    <!-- Dashboard action with graph as default -->
    <record id="action_service_request_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">baladiya.service.request</field>
        <field name="view_mode">graph,pivot,list</field>
        <field name="view_ids" eval="[
            (5, 0, 0),
            (0, 0, {'view_mode': 'graph', 'view_id': ref('view_service_request_graph_bar')}),
            (0, 0, {'view_mode': 'pivot', 'view_id': ref('view_service_request_pivot')}),
            (0, 0, {'view_mode': 'list', 'view_id': ref('view_service_request_list')}),
        ]"/>
        <field name="search_view_id" ref="view_service_request_search"/>
    </record>

</odoo>
