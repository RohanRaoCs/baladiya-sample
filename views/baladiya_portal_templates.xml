<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================== PORTAL HOME COUNTER ==================== -->
    <template id="portal_my_home_baladiya" name="Portal My Home: Baladiya"
              inherit_id="portal.portal_my_home" priority="40">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="icon" t-value="'/baladiya/static/description/icon.png'"/>
                <t t-set="title">Service Requests</t>
                <t t-set="url" t-value="'/my/requests'"/>
                <t t-set="text">View and track your municipal service requests</t>
                <t t-set="placeholder_count" t-value="'request_count'"/>
            </t>
        </div>
    </template>

    <!-- ==================== SERVICE CATALOG ==================== -->
    <template id="portal_services_catalog" name="Service Catalog">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="1"/>

            <div class="baladiya-portal">
                <div class="text-center mb-4">
                    <h2 class="baladiya-heading">Municipal Services</h2>
                    <p class="text-muted">Select a service to submit your request</p>
                </div>

                <div class="row g-4">
                    <t t-foreach="categories" t-as="cat">
                        <div class="col-md-4 col-sm-6">
                            <div class="card baladiya-service-card h-100 shadow-sm">
                                <div class="card-body text-center">
                                    <div class="baladiya-icon-circle mb-3">
                                        <i t-att-class="cat.icon + ' fa-2x'"/>
                                    </div>
                                    <h5 class="card-title fw-bold" t-field="cat.name"/>
                                    <p class="card-text text-muted small" t-raw="cat.description"/>
                                    <div class="d-flex justify-content-between align-items-center mt-3 mb-3">
                                        <span class="baladiya-fee">
                                            <t t-if="cat.fee_amount > 0">
                                                <strong><t t-esc="cat.fee_amount"/> AED</strong>
                                            </t>
                                            <t t-else="">
                                                <span class="text-success fw-bold">Free</span>
                                            </t>
                                        </span>
                                        <span class="text-muted small">
                                            <i class="fa fa-clock-o"/> <t t-esc="cat.estimated_days"/> days
                                        </span>
                                    </div>
                                    <a t-attf-href="/my/services/apply/#{cat.id}"
                                       class="btn btn-primary baladiya-btn w-100">
                                        Apply Now
                                    </a>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== APPLICATION FORM ==================== -->
    <template id="portal_service_apply" name="Apply for Service">
        <t t-call="portal.portal_layout">
            <div class="baladiya-portal">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="card shadow-sm">
                            <div class="card-header baladiya-card-header">
                                <h4 class="mb-0">
                                    <i t-att-class="category.icon"/> Apply: <t t-esc="category.name"/>
                                </h4>
                            </div>
                            <div class="card-body">
                                <!-- Service Info -->
                                <div class="alert alert-info">
                                    <div class="d-flex justify-content-between">
                                        <span><strong>Fee:</strong>
                                            <t t-if="category.fee_amount > 0">
                                                <t t-esc="category.fee_amount"/> AED
                                            </t>
                                            <t t-else="">Free</t>
                                        </span>
                                        <span><strong>Estimated:</strong> <t t-esc="category.estimated_days"/> days</span>
                                    </div>
                                    <t t-if="category.required_documents">
                                        <hr/>
                                        <strong>Required Documents:</strong>
                                        <pre class="mb-0 small" style="white-space:pre-wrap;" t-esc="category.required_documents"/>
                                    </t>
                                </div>

                                <form action="/my/services/submit" method="post"
                                      enctype="multipart/form-data">
                                    <input type="hidden" name="csrf_token"
                                           t-att-value="request.csrf_token()"/>
                                    <input type="hidden" name="category_id"
                                           t-att-value="category.id"/>

                                    <!-- Citizen Info (read-only) -->
                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Applicant</label>
                                        <input type="text" class="form-control" readonly="readonly"
                                               t-att-value="partner.name"/>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold">Email</label>
                                        <input type="text" class="form-control" readonly="readonly"
                                               t-att-value="partner.email"/>
                                    </div>

                                    <!-- Description -->
                                    <div class="mb-3">
                                        <label for="description" class="form-label fw-bold">
                                            Description <span class="text-danger">*</span>
                                        </label>
                                        <textarea name="description" class="form-control" rows="4"
                                                  required="required"
                                                  placeholder="Please describe your request in detail..."/>
                                    </div>

                                    <!-- District -->
                                    <div class="mb-3">
                                        <label for="district" class="form-label fw-bold">
                                            District <span class="text-danger">*</span>
                                        </label>
                                        <select name="district" class="form-select" required="required">
                                            <option value="">Select district...</option>
                                            <t t-foreach="districts" t-as="d">
                                                <option t-att-value="d[0]" t-esc="d[1]"/>
                                            </t>
                                        </select>
                                    </div>

                                    <!-- Address -->
                                    <div class="mb-3">
                                        <label for="address" class="form-label fw-bold">
                                            Location / Address
                                        </label>
                                        <textarea name="address" class="form-control" rows="2"
                                                  placeholder="Provide the specific location or address..."/>
                                    </div>

                                    <!-- File Upload -->
                                    <div class="mb-3">
                                        <label for="attachments" class="form-label fw-bold">
                                            Upload Documents
                                        </label>
                                        <input type="file" name="attachments" class="form-control"
                                               multiple="multiple"
                                               accept=".pdf,.jpg,.jpeg,.png,.doc,.docx"/>
                                        <small class="text-muted">PDF, JPG, PNG, DOC accepted. Max 10MB each.</small>
                                    </div>

                                    <div class="d-flex gap-2">
                                        <button type="submit" class="btn btn-primary baladiya-btn">
                                            <i class="fa fa-paper-plane"/> Submit Request
                                        </button>
                                        <a href="/my/services" class="btn btn-secondary">Cancel</a>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== SUBMISSION CONFIRMATION ==================== -->
    <template id="portal_service_submitted" name="Request Submitted">
        <t t-call="portal.portal_layout">
            <div class="baladiya-portal">
                <div class="row justify-content-center">
                    <div class="col-lg-6">
                        <div class="card shadow-sm text-center">
                            <div class="card-body p-5">
                                <div class="mb-4">
                                    <span style="font-size:64px;">✅</span>
                                </div>
                                <h3 class="baladiya-heading">Request Submitted Successfully!</h3>
                                <p class="text-muted">Your request has been received and is being processed.</p>

                                <div class="baladiya-tracking-box my-4">
                                    <small class="text-muted d-block mb-1">Your Tracking Code</small>
                                    <h2 class="baladiya-tracking-code" t-esc="request.tracking_code"/>
                                    <small class="text-muted">Save this code to track your request status</small>
                                </div>

                                <table class="table table-sm text-start">
                                    <tr>
                                        <td class="fw-bold">Request Number</td>
                                        <td t-esc="request.name"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Service</td>
                                        <td t-esc="request.category_id.name"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Department</td>
                                        <td t-esc="request.department_id.name"/>
                                    </tr>
                                    <tr>
                                        <td class="fw-bold">Estimated Processing</td>
                                        <td><t t-esc="request.category_id.estimated_days"/> working days</td>
                                    </tr>
                                </table>

                                <div class="d-flex gap-2 justify-content-center mt-4">
                                    <a href="/my/requests" class="btn btn-primary baladiya-btn">
                                        View My Requests
                                    </a>
                                    <a href="/my/services" class="btn btn-outline-primary">
                                        Submit Another
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== MY REQUESTS LIST ==================== -->
    <template id="portal_my_requests" name="My Requests">
        <t t-call="portal.portal_layout">
            <div class="baladiya-portal">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="baladiya-heading mb-0">My Service Requests</h2>
                    <a href="/my/services" class="btn btn-primary baladiya-btn">
                        <i class="fa fa-plus"/> New Request
                    </a>
                </div>

                <t t-if="not requests">
                    <div class="text-center py-5">
                        <i class="fa fa-inbox fa-3x text-muted mb-3 d-block"/>
                        <p class="text-muted">You have no service requests yet.</p>
                        <a href="/my/services" class="btn btn-primary baladiya-btn">
                            Browse Services
                        </a>
                    </div>
                </t>

                <t t-if="requests">
                    <div class="table-responsive">
                        <table class="table table-hover">
                            <thead class="baladiya-table-header">
                                <tr>
                                    <th>Tracking Code</th>
                                    <th>Service</th>
                                    <th>Department</th>
                                    <th>Submitted</th>
                                    <th>Status</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="requests" t-as="req">
                                    <tr>
                                        <td>
                                            <a t-attf-href="/my/requests/#{req.id}" class="fw-bold">
                                                <t t-esc="req.tracking_code"/>
                                            </a>
                                        </td>
                                        <td t-esc="req.category_id.name"/>
                                        <td t-esc="req.department_id.name"/>
                                        <td t-esc="req.submission_date"/>
                                        <td>
                                            <span t-attf-class="badge baladiya-badge-#{req.state}"
                                                  t-esc="dict(req._fields['state'].selection).get(req.state)"/>
                                        </td>
                                        <td>
                                            <a t-attf-href="/my/requests/#{req.id}"
                                               class="btn btn-sm btn-outline-primary">
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </div>
                </t>
            </div>
        </t>
    </template>

    <!-- ==================== REQUEST DETAIL ==================== -->
    <template id="portal_request_detail" name="Request Detail">
        <t t-call="portal.portal_layout">
            <div class="baladiya-portal">
                <div class="mb-3">
                    <a href="/my/requests" class="text-muted">
                        <i class="fa fa-arrow-left"/> Back to My Requests
                    </a>
                </div>

                <div class="card shadow-sm">
                    <div class="card-header baladiya-card-header d-flex justify-content-between align-items-center">
                        <h4 class="mb-0">
                            <t t-esc="req.name"/> — <t t-esc="req.tracking_code"/>
                        </h4>
                        <span t-attf-class="badge baladiya-badge-#{req.state} fs-6"
                              t-esc="dict(req._fields['state'].selection).get(req.state)"/>
                    </div>
                    <div class="card-body">

                        <!-- Progress Stepper -->
                        <div class="baladiya-stepper mb-4">
                            <div class="d-flex justify-content-between position-relative">
                                <div class="baladiya-stepper-line"/>
                                <t t-set="state_list" t-value="[s[0] for s in stages]"/>
                                <t t-set="current_idx" t-value="state_list.index(req.state) if req.state in state_list else -1"/>
                                <t t-foreach="stages" t-as="stage">
                                    <t t-set="stage_idx" t-value="stage_index"/>
                                    <div t-attf-class="baladiya-step #{'active' if stage_idx == current_idx else ('completed' if stage_idx &lt; current_idx else '')}">
                                        <div class="baladiya-step-circle">
                                            <t t-if="stage_idx &lt; current_idx">
                                                <i class="fa fa-check"/>
                                            </t>
                                            <t t-elif="stage_idx == current_idx">
                                                <i class="fa fa-circle"/>
                                            </t>
                                            <t t-else="">
                                                <span t-esc="stage_idx + 1"/>
                                            </t>
                                        </div>
                                        <small class="baladiya-step-label" t-esc="stage[1]"/>
                                    </div>
                                </t>
                            </div>
                        </div>

                        <t t-if="req.state == 'rejected'">
                            <div class="alert alert-danger">
                                <strong>Request Rejected</strong>
                                <t t-if="req.rejection_reason">
                                    <p class="mb-0 mt-1" t-esc="req.rejection_reason"/>
                                </t>
                            </div>
                        </t>

                        <!-- Request Info -->
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="fw-bold text-muted">REQUEST INFORMATION</h6>
                                <table class="table table-sm">
                                    <tr><td class="fw-bold">Service</td><td t-esc="req.category_id.name"/></tr>
                                    <tr><td class="fw-bold">Department</td><td t-esc="req.department_id.name"/></tr>
                                    <tr><td class="fw-bold">District</td><td t-esc="dict(req._fields['district'].selection).get(req.district, '-')"/></tr>
                                    <tr><td class="fw-bold">Address</td><td t-esc="req.address or '-'"/></tr>
                                </table>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold text-muted">DATES &amp; SLA</h6>
                                <table class="table table-sm">
                                    <tr><td class="fw-bold">Submitted</td><td t-esc="req.submission_date or '-'"/></tr>
                                    <tr><td class="fw-bold">Deadline</td><td t-esc="req.deadline or '-'"/></tr>
                                    <tr><td class="fw-bold">Completed</td><td t-esc="req.completion_date or '-'"/></tr>
                                    <tr>
                                        <td class="fw-bold">Fee</td>
                                        <td>
                                            <t t-esc="req.fee_amount"/> AED
                                            <t t-if="req.fee_paid">
                                                <span class="badge text-bg-success">Paid</span>
                                            </t>
                                            <t t-else="">
                                                <span class="badge text-bg-warning">Pending</span>
                                            </t>
                                        </td>
                                    </tr>
                                </table>
                            </div>
                        </div>

                        <t t-if="req.description">
                            <h6 class="fw-bold text-muted">DESCRIPTION</h6>
                            <div class="border rounded p-3 mb-3" t-raw="req.description"/>
                        </t>

                        <!-- Documents -->
                        <t t-if="req.attachment_ids">
                            <h6 class="fw-bold text-muted">DOCUMENTS</h6>
                            <ul class="list-group mb-3">
                                <t t-foreach="req.attachment_ids" t-as="att">
                                    <li class="list-group-item d-flex align-items-center">
                                        <i class="fa fa-file-o me-2"/>
                                        <t t-esc="att.name"/>
                                    </li>
                                </t>
                            </ul>
                        </t>

                        <!-- Feedback Form (only when done) -->
                        <t t-if="req.state == 'done'">
                            <div class="card bg-light mt-4">
                                <div class="card-body">
                                    <h5>Rate Your Experience</h5>
                                    <t t-if="req.citizen_rating">
                                        <p>Thank you for your feedback!</p>
                                        <p><strong>Rating:</strong> <t t-esc="req.citizen_rating"/> / 5</p>
                                        <t t-if="req.citizen_feedback">
                                            <p><strong>Feedback:</strong> <t t-esc="req.citizen_feedback"/></p>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <form t-attf-action="/my/requests/#{req.id}/feedback" method="post">
                                            <input type="hidden" name="csrf_token"
                                                   t-att-value="request.csrf_token()"/>
                                            <div class="mb-3">
                                                <label class="form-label fw-bold">Rating</label>
                                                <select name="rating" class="form-select" required="required">
                                                    <option value="">Select rating...</option>
                                                    <option value="5">5 - Excellent</option>
                                                    <option value="4">4 - Very Good</option>
                                                    <option value="3">3 - Good</option>
                                                    <option value="2">2 - Fair</option>
                                                    <option value="1">1 - Poor</option>
                                                </select>
                                            </div>
                                            <div class="mb-3">
                                                <label class="form-label fw-bold">Feedback</label>
                                                <textarea name="feedback" class="form-control" rows="3"
                                                          placeholder="Share your experience..."/>
                                            </div>
                                            <button type="submit" class="btn btn-primary baladiya-btn">
                                                Submit Feedback
                                            </button>
                                        </form>
                                    </t>
                                </div>
                            </div>
                        </t>

                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== PUBLIC TRACKING PAGE ==================== -->
    <template id="portal_track" name="Track Request">
        <t t-call="portal.portal_layout">
            <div class="baladiya-portal">
                <div class="row justify-content-center">
                    <div class="col-lg-6">
                        <div class="card shadow-sm">
                            <div class="card-body text-center p-5">
                                <div class="mb-4">
                                    <i class="fa fa-search fa-3x" style="color:#1565C0;"/>
                                </div>
                                <h3 class="baladiya-heading">Track Your Request</h3>
                                <p class="text-muted">Enter your tracking code to check the current status of your service request.</p>

                                <form action="/track/result" method="get" class="mt-4">
                                    <div class="input-group input-group-lg">
                                        <input type="text" name="code" class="form-control text-center"
                                               placeholder="e.g. BLD-2026-A7X9"
                                               required="required" style="font-size:1.3em;letter-spacing:2px;"/>
                                        <button type="submit" class="btn btn-primary baladiya-btn">
                                            <i class="fa fa-search"/> Track
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </t>
    </template>

    <!-- ==================== TRACKING RESULT ==================== -->
    <template id="portal_track_result" name="Tracking Result">
        <t t-call="portal.portal_layout">
            <div class="baladiya-portal">
                <div class="row justify-content-center">
                    <div class="col-lg-8">
                        <div class="mb-3">
                            <a href="/track" class="text-muted">
                                <i class="fa fa-arrow-left"/> Track Another Request
                            </a>
                        </div>

                        <t t-if="not req">
                            <div class="card shadow-sm">
                                <div class="card-body text-center p-5">
                                    <i class="fa fa-times-circle fa-3x text-danger mb-3 d-block"/>
                                    <h4>Request Not Found</h4>
                                    <p class="text-muted">
                                        No request found with tracking code
                                        <strong t-esc="tracking_code"/>.
                                        Please check the code and try again.
                                    </p>
                                    <a href="/track" class="btn btn-primary baladiya-btn mt-2">
                                        Try Again
                                    </a>
                                </div>
                            </div>
                        </t>

                        <t t-if="req">
                            <div class="card shadow-sm">
                                <div class="card-header baladiya-card-header d-flex justify-content-between align-items-center">
                                    <h4 class="mb-0">Tracking: <t t-esc="req.tracking_code"/></h4>
                                    <span t-attf-class="badge baladiya-badge-#{req.state} fs-6"
                                          t-esc="dict(req._fields['state'].selection).get(req.state)"/>
                                </div>
                                <div class="card-body">

                                    <!-- Progress Stepper -->
                                    <div class="baladiya-stepper mb-4">
                                        <div class="d-flex justify-content-between position-relative">
                                            <div class="baladiya-stepper-line"/>
                                            <t t-set="state_list" t-value="[s[0] for s in stages]"/>
                                            <t t-set="current_idx" t-value="state_list.index(req.state) if req.state in state_list else -1"/>
                                            <t t-foreach="stages" t-as="stage">
                                                <t t-set="stage_idx" t-value="stage_index"/>
                                                <div t-attf-class="baladiya-step #{'active' if stage_idx == current_idx else ('completed' if stage_idx &lt; current_idx else '')}">
                                                    <div class="baladiya-step-circle">
                                                        <t t-if="stage_idx &lt; current_idx">
                                                            <i class="fa fa-check"/>
                                                        </t>
                                                        <t t-elif="stage_idx == current_idx">
                                                            <i class="fa fa-circle"/>
                                                        </t>
                                                        <t t-else="">
                                                            <span t-esc="stage_idx + 1"/>
                                                        </t>
                                                    </div>
                                                    <small class="baladiya-step-label" t-esc="stage[1]"/>
                                                </div>
                                            </t>
                                        </div>
                                    </div>

                                    <div class="row">
                                        <div class="col-md-6">
                                            <table class="table table-sm">
                                                <tr><td class="fw-bold">Service</td><td t-esc="req.category_id.name"/></tr>
                                                <tr><td class="fw-bold">Department</td><td t-esc="req.department_id.name"/></tr>
                                                <tr><td class="fw-bold">Submitted</td><td t-esc="req.submission_date or '-'"/></tr>
                                            </table>
                                        </div>
                                        <div class="col-md-6">
                                            <table class="table table-sm">
                                                <tr><td class="fw-bold">Deadline</td><td t-esc="req.deadline or '-'"/></tr>
                                                <tr><td class="fw-bold">District</td><td t-esc="dict(req._fields['district'].selection).get(req.district, '-')"/></tr>
                                                <tr>
                                                    <td class="fw-bold">SLA</td>
                                                    <td>
                                                        <t t-if="req.sla_status == 'on_track'">
                                                            <span class="badge text-bg-success">On Track</span>
                                                        </t>
                                                        <t t-elif="req.sla_status == 'at_risk'">
                                                            <span class="badge text-bg-warning">At Risk</span>
                                                        </t>
                                                        <t t-elif="req.sla_status == 'overdue'">
                                                            <span class="badge text-bg-danger">Overdue</span>
                                                        </t>
                                                        <t t-else="">-</t>
                                                    </td>
                                                </tr>
                                            </table>
                                        </div>
                                    </div>

                                    <t t-if="req.state == 'rejected' and req.rejection_reason">
                                        <div class="alert alert-danger mt-2">
                                            <strong>Rejection Reason:</strong>
                                            <t t-esc="req.rejection_reason"/>
                                        </div>
                                    </t>
                                </div>
                            </div>
                        </t>
                    </div>
                </div>
            </div>
        </t>
    </template>

</odoo>
